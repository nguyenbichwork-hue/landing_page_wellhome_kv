# URL Google Apps Script Web App nhận đơn (dán URL .../exec sau khi deploy apps-script/Code.gs)
VITE_ORDER_ENDPOINT=https://script.google.com/macros/s/PASTE_YOUR_DEPLOYMENT_ID/exec

# (Tùy chọn) Token Haravan — chỉ dùng khi chạy lại `npm run data` để cập nhật sản phẩm.
# Không bắt buộc cho việc chạy/triển khai web (dữ liệu đã được build sẵn vào src/data/products.json).
# KHÔNG commit token thật lên Git. Đặt qua biến môi trường khi cần.
HARAVAN_TOKEN=paste_haravan_token_here_only_local
